{
  "codesnap.backgroundColor": "#ffffff",
  "codesnap.boxShadow": "rgba(0, 0, 0, 0) 0px 0px 0px",
  "codesnap.transparentBackground": true,
  "editor.inlayHints.enabled": "off",
  "editor.rulers": [
    79
  ],
  "editor.stickyScroll.enabled": true,
  "editor.tabSize": 4,
  "explorer.compactFolders": false,
  "explorer.decorations.badges": false,
  "explorer.decorations.colors": false,
  "files.autoSave": "afterDelay",
  "files.autoSaveDelay": 1000,
  "latex-workshop.latex.autoBuild.cleanAndRetry.enabled": true,
  "latex-workshop.latex.clean.subfolder.enabled": true,
  "latex-workshop.latex.outDir": "%DIR%/build",
  "notebook.lineNumbers": "on",
  "platformio-ide.useDevelopmentPIOCore": true,
  "pylint.args": [
    "--disable=C0114",
    "--disable=C0325",
    "--disable=C0116"
  ],
  "python.analysis.extraPaths": [
    "/opt/ros/jazzy/lib/python3.12/site-packages"
  ],
  "python.analysis.indexing": true,
  "python.analysis.typeCheckingMode": "basic",
  "python.autoComplete.extraPaths": [
    "/opt/ros/jazzy/lib/python3.12/site-packages"
  ],
  "remote.SSH.path": "/usr/bin/ssh",
  "remote.SSH.remotePlatform": {
    "vm": "linux"
  },
  "remote.SSH.useLocalServer": false,
  "rust-analyzer.inlayHints.typeHints.enable": false,
  "rust-analyzer.lens.enable": false,
  "vim.handleKeys": {
    "<C-p>": false
  },
  "vim.hlsearch": true,
  "vim.incsearch": true,
  "vim.smartRelativeLine": true,
  "vim.useSystemClipboard": true,
  "window.commandCenter": false,
  "workbench.colorTheme": "Monokai",
  "workbench.editor.doubleClickTabToToggleEditorGroupSizes": "off",
  "workbench.editor.enablePreview": false,
  "workbench.preferredDarkColorTheme": "Monokai",
  "workbench.settings.editor": "json",
  "workbench.startupEditor": "none"
}
